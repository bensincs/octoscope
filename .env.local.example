# GitHub OAuth App credentials.
# Create one at: https://github.com/settings/developers  →  "New OAuth App"
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# NextAuth v5 (Auth.js) — generate a secret with:  openssl rand -base64 32
AUTH_SECRET=replace_with_a_long_random_string
AUTH_URL=http://localhost:3000

# Postgres (local docker-compose default shown). Matches docker-compose.yml.
DATABASE_URL=postgres://hygiene:hygiene@localhost:5432/hygiene

# PAT-at-rest encryption key (AES-256-GCM). MUST be 32 bytes, base64-encoded.
# Generate with:  openssl rand -base64 32
PAT_ENCRYPTION_KEY=replace_with_a_32_byte_base64_key
